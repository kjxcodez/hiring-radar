OPENROUTER_API_KEY=
OUTPUT_DIR=output
REQUEST_DELAY_SECONDS=1.5
LOG_LEVEL=INFO

# --- SMTP / Outreach configuration ---
# For Gmail, you must enable 2-Step Verification on your account, then generate
# an App Password. See Google's docs: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_APP_PASSWORD=
